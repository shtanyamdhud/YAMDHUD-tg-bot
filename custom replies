bot.on('message', (msg) => {
  const text = msg.text.toLowerCase();

  if (text.includes("hi")) {
    bot.sendMessage(msg.chat.id, "Hello bhai 😎");
  } 
  else if (text.includes("help")) {
    bot.sendMessage(msg.chat.id, "Kya help chahiye?");
  } 
  else {
    bot.sendMessage(msg.chat.id, "Samajh nahi aaya 😅");
  }
});
